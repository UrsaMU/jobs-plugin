{
  "name": "@ursamu/jobs-plugin",
  "tasks": {
    "test": "deno test --allow-all --unstable-kv --no-check tests/",
    "showcase": "deno run --allow-all --unstable-kv tools/showcase.ts"
  },
  "version": "1.2.0",
  "description": "Anomaly-style job/request tracking system for UrsaMU — player requests, staff commands, bucket access, archive, and REST API.",
  "license": "MIT",
  "exports": "./mod.ts",
  "publish": {
    "include": ["src", "mod.ts", "index.ts", "deno.json", "ursamu.plugin.json", "LICENSE", "README.md"],
    "exclude": ["tests"]
  },
  "imports": {
    "@ursamu/ursamu": "jsr:@ursamu/ursamu@^2.0",
    "@ursamu/ursamu/cmd-parser": "https://jsr.io/@ursamu/ursamu/2.0.0/src/services/commands/cmdParser.ts",
    "@std/assert":         "jsr:@std/assert@^0.224.0",
    "@std/testing":        "jsr:@std/testing@^0.224.0",
    "@std/flags":          "jsr:@std/flags@^0.224.0",
    "@std/fs":             "jsr:@std/fs@^0.224.0",
    "@std/path":           "jsr:@std/path@^0.224.0"
  }
}
